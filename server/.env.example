PORT=5000
MONGO_URI=mongodb://localhost:27017/visstream
JWT_SECRET=your_super_secret_jwt_key_change_in_production
CLIENT_URL=http://localhost:5173
# Optional: add multiple comma-separated origins, e.g.
# CLIENT_URL=http://localhost:5173,http://192.168.1.20:5173
VIDEOS_DIR=uploads/videos
HLS_DIR=uploads/hls
NODE_ENV=development

# Test account bootstrap (enabled by default in non-production)
ENABLE_DEFAULT_TEST_USER=true
DEFAULT_TEST_EMAIL=test@gmail.com
DEFAULT_TEST_PASSWORD=123123
DEFAULT_TEST_USERNAME=testuser
